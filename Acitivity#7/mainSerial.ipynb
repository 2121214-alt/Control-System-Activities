import serial
import time

def move_servo():
    # Configure the serial port (Change 'COM3' to your specific port)
    port = 'COM3' 
    baudrate = 9600

    try:
        ser = serial.Serial(port, baudrate, timeout=1)
        # Arduino resets when serial opens; wait for it to initialize
        time.sleep(2) 
        print(f"Connected to Arduino on {port}")
    except serial.SerialException as e:
        print(f"Error: Could not open serial port {port}. {e}")
        return

    while True:
        user_input = input("Enter angle (0-180) or 'q' to quit: ").strip()

        if user_input.lower() == 'q':
            break

        try:
            angle = int(user_input)
            
            if 0 <= angle <= 180:
                # Send the angle followed by a newline character
                data_to_send = f"{angle}\n"
                ser.write(data_to_send.encode('utf-8'))
                
                time.sleep(0.1)
                if ser.in_waiting > 0:
                    response = ser.readline().decode('utf-8').strip()
                    print(f"Arduino says: {response}")
            else:
                print("Error: Input must be between 0 and 180.")
                
        except ValueError:
            print("Error: Invalid input. Please enter a whole number.")

    ser.close()
    print("Connection closed.")

if __name__ == "__main__":
    move_servo()
